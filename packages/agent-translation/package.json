{
  "name": "@nextpay-ai/agent-translation",
  "version": "0.1.0",
  "description": "Agent-driven, type-enforced i18n for TypeScript and React",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./react": {
      "import": "./src/react.tsx",
      "types": "./src/react.tsx"
    },
    "./eslint": {
      "import": "./src/eslint-plugin.ts",
      "types": "./src/eslint-plugin.ts"
    }
  },
  "bin": {
    "agent-translation": "./cli/index.ts"
  },
  "files": [
    "src",
    "cli",
    "skills"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "@typescript-eslint/utils": "^8.0.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^18.0.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@typescript-eslint/rule-tester": "^8.58.0",
    "happy-dom": "14",
    "jsdom": "^29.0.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.5.0"
  }
}
