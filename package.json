{
  "name": "agent-translation-workspace",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test --cwd packages/agent-translation",
    "build": "bun run --cwd packages/agent-translation build",
    "build:demo": "bun run --cwd packages/agent-translation build && bun run --cwd packages/demo build",
    "dev:demo": "bun run --cwd packages/demo dev"
  }
}
